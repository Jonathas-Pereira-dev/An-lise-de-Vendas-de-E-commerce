# Exemplo de configuração de conexão PostgreSQL
# Copie este arquivo para .env e ajuste os valores antes de executar o pipeline.

DB_USER=meu_usuario
DB_PASSWORD=minha_senha
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce

# Ou defina a URL completa de conexão:
# DATABASE_URL=postgresql://meu_usuario:minha_senha@localhost:5432/ecommerce
